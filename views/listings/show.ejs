<% layout("/layouts/boilerplate") %>

  <h3>Listing Details</h3>

  <div class="card" style="width: 22rem;">
    <img src="<%= listing.image?.url || '/default.jpg' %>" class="card-img-top show-img">

    <div class="card-body">
      <h5 class="card-title">
        <%= listing.title %>
      </h5>
      <p class="card-text">
        <%= listing.description %>
      </p>
    </div>

    <ul class="list-group list-group-flush">
      <li class="list-group-item">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
      </li>
      <li class="list-group-item">
        <%= listing.location %>
      </li>
      <li class="list-group-item">
        <%= listing.country %>
      </li>
    </ul>

    <div class="card-body">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger">Delete</button>
      </form>
    </div>
  </div>