<% layout("/layouts/boilerplate") %>

  <h3>Listing Details</h3>

  <div class="card listing-card" style="width: 22rem;" >
    <img src="<%= listing.image?.url || '/default.jpg' %>" class="card-img-top show-img">

    <div class="card-body" >
      <h5 class="card-title">
        <%= listing.title %>
      </h5>
      <p class="card-text">
        <%= listing.description %>
      </p>
    </div>

    <ul class="list-group list-group-flush">
      <li class="list-group-item">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
      </li>
      <li class="list-group-item">
        <%= listing.location %>
      </li>
      <li class="list-group-item">
        <%= listing.country %>
      </li>
    </ul>

    <div class="card-body">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger">Delete</button>
      </form>
    </div>

    <div class="col-8 offset-3 mb-3">
      <h4>Leave Review</h4>
      <hr>
      <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" >
        </div>
        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
      </form>


      <hr>


      <h4>All Reviews</h4>
        <div class="row">
        <% for(review of listing.reviews){ %>
          <div class="card col-5 ms-2 mb-3">
              <div class="card-body">
                <h5 class="card-title">Harsh Chavan</h5>
                <p class="card-text"><%= review.comment%></p>
                <div class="card-text"><%= review.rating%> Stars</div>
              </div>
          <form method="POST" action="/listings/<%= listing._id%>/reviews/<%=review._id%>?_method=DELETE" class="mb-3">
            <button class="btn btn-sm btn-dark">Delete</button>
          </form>

          </div>

       <% }%>          
        </div>

    </div>
  </div>